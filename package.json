{
  "name": "stutzjs",
  "version": "0.0.12",
  "description": "Formats currency values",
  "main": "./dist/stutz.cjs",
  "module": "./dist/stutz.mjs",
  "types": "./dist/stutz.d.ts",
  "unpkg": "./dist/stutz.standalone.js",
  "jsdelivr": "./dist/stutz.standalone.js",
  "exports": {
    ".": {
      "types": "./dist/stutz.d.ts",
      "import": "./dist/stutz.mjs",
      "require": "./dist/stutz.cjs"
    },
    "./standalone": "./dist/stutz.standalone.js"
  },
  "files": [
    "dist/stutz.cjs",
    "dist/stutz.mjs",
    "dist/stutz.d.ts",
    "dist/stutz.d.mts",
    "dist/stutz.standalone.js",
    "dist/*.map",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elekktrisch/stutzjs.git"
  },
  "keywords": [
    "currency",
    "formatting",
    "bigdecimal"
  ],
  "author": "Roman Schlegel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elekktrisch/stutzjs/issues"
  },
  "homepage": "https://github.com/elekktrisch/stutzjs#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "big.js": "^6.2.2"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^20.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
